<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF"
    android:id="@+id/main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── TOP BRAND BLOCK ─────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:background="#1A3C8F"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- Icon circle -->

            <LinearLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/circle_white_alpha"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-light"
                    android:text="✓"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="EduTrack"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.03" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Staff Attendance System"
                android:textColor="#A8C0E8"
                android:textSize="13sp"
                android:letterSpacing="0.04" />

        </LinearLayout>

        <!-- ── WHITE CARD ──────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_top_rounded"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="40dp"
            android:layout_marginTop="-24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign In"
                android:textColor="#0D1B3E"
                android:textSize="22sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"
                android:text="Select your role to continue"
                android:textColor="#7A8BB0"
                android:textSize="13sp" />

            <!-- ── ROLE TOGGLE ─────────────────────────────── -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTeacher"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="Teacher"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/toggle_text_selector"
                    app:backgroundTint="@color/toggle_bg_selector"
                    app:strokeColor="#1A3C8F"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="10dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAdmin"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="Admin"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/toggle_text_selector"
                    app:backgroundTint="@color/toggle_bg_selector"
                    app:strokeColor="#1A3C8F"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="10dp" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- ── DIVIDER ──────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="22dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E4EAF4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:text="Enter credentials"
                    android:textColor="#9AAABB"
                    android:textSize="12sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E4EAF4" />

            </LinearLayout>

            <!-- ── EMAIL FIELD ─────────────────────────────── -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEmail"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:hint="Mobile No"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#C8D4F0"
                app:boxStrokeWidth="1.5dp"
                app:boxBackgroundColor="#F6F8FF"
                app:hintTextColor="#7A8BB0">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:imeOptions="actionNext"
                    android:textSize="15sp"
                    android:textColor="#0D1B3E" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── PASSWORD FIELD ──────────────────────────── -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Password"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#C8D4F0"
                app:boxStrokeWidth="1.5dp"
                app:boxBackgroundColor="#F6F8FF"
                app:hintTextColor="#7A8BB0"
                app:endIconMode="password_toggle"
                app:endIconTint="#8098C8">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:imeOptions="actionDone"
                    android:textSize="15sp"
                    android:textColor="#0D1B3E" />

            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:orientation="horizontal">


                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Remember me"/>

<!--                &lt;!&ndash; ── ROLE CHIP ────────────────────────────────── &ndash;&gt;-->
<!--                <TextView-->
<!--                    android:id="@+id/tvRoleChip"-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:layout_marginTop="12dp"-->
<!--                    android:gravity="center"-->
<!--                    android:layout_gravity="end"-->
<!--                    android:background="@drawable/bg_chip"-->
<!--                    android:paddingStart="12dp"-->
<!--                    android:paddingEnd="12dp"-->
<!--                    android:paddingTop="5dp"-->
<!--                    android:paddingBottom="5dp"-->
<!--                    android:text="● Signing in as Teacher"-->
<!--                    android:textColor="#1A3C8F"-->
<!--                    android:textSize="12sp" />-->
            </LinearLayout>



            <!-- ── LOGIN BUTTON ────────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="15dp"
                android:text="Sign In"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.02"
                app:backgroundTint="#1A3C8F"
                app:cornerRadius="14dp"
                android:textColor="#FFFFFF" />

            <!-- ── PROGRESS BAR ────────────────────────────── -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:visibility="invisible"
                app:indicatorColor="#1A3C8F"
                app:trackColor="#E4EAF4"
                 />

            <!-- ── ERROR TEXT ──────────────────────────────── -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text=""
                android:textColor="#D32F2F"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- ── FOOTER NOTE ─────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:text="No account? Contact your school administrator."
                android:textColor="#B0BCCC"
                android:textSize="12sp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>