<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── HEADER ───────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A3C8F"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">

            <!-- Profile circle — shows first letter of name -->
            <LinearLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_profile_circle"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvProfileInitial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="T"
                    android:textColor="#1A3C8F"
                    android:textSize="32sp"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            <!-- Name + Designation -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Teacher Name"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvDesignation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Teacher"
                    android:textColor="#A8C0E8"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Class"
                    android:textColor="#A8C0E8"/>

            </LinearLayout>

            <!-- Notification bell -->
            <TextView
                android:id="@+id/tvNotification"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="🔔"
                android:textSize="20sp"
                android:background="@drawable/bg_profile_circle"
                android:padding="8dp" />

        </LinearLayout>

        <!-- ── DATE BAR ─────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#162E6E"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Monday, June 02"
                android:textColor="#A8C0E8"
                android:textSize="12sp" />

            <!-- Today's status chip -->
            <TextView
                android:id="@+id/tvTodayStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_pending"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="Pending"
                android:textColor="#E65100"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

        <!-- ── ATTENDANCE BLOCK ──────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Card header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Attendance"
                        android:textColor="#0D1B3E"
                        android:textSize="17sp"
                        android:fontFamily="sans-serif-medium" />

                    <!-- Condition dots -->
                    <View
                        android:id="@+id/dotLocation"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/dot_gray" />

                    <View
                        android:id="@+id/dotTime"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/dot_gray" />

                </LinearLayout>

                <!-- ── SWIPE BUTTON ──────────────────────── -->
                <FrameLayout
                    android:id="@+id/swipeContainer"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_swipe_container">

                    <!-- Background label -->
                    <TextView
                        android:id="@+id/tvSwipeLabel"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="→  Swipe to Mark Attendance"
                        android:textColor="#6B8CC8"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <!-- Draggable thumb -->
                    <View
                        android:id="@+id/swipeThumb"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center_vertical|start"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_swipe_thumb" />

                </FrameLayout>

                <!-- Attendance time window -->
                <TextView
                    android:id="@+id/tvTimeWindow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="⏰  Attendance window: 07:45 – 08:15"
                    android:textColor="#9AAABB"
                    android:textSize="12sp" />

                <!-- Status message shown after conditions checked -->
                <TextView
                    android:id="@+id/tvConditionMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:text=""
                    android:textSize="12sp"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── 7 DAY HISTORY — Horizontal Scroll ────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp"
            android:text="Last 7 Days"
            android:textColor="#0D1B3E"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_margin="5dp"
            android:clipToPadding="false"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/llHistoryCards"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

        </HorizontalScrollView>

        <!-- ── NOTICE BOARD BLOCK ────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp"
            android:text="Notice Board"
            android:textColor="#0D1B3E"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="No notices at this time"
                    android:textColor="#9AAABB"
                    android:textSize="13sp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>